# 1. Forzar que el inicio sea nuestro archivo CJS
DirectoryIndex app.cjs
Options -Indexes

# 2. ConfiguraciĻŪn de Passenger para CommonJS
PassengerEnabled On
PassengerAppEnv production
PassengerAppRoot /home/prealcac/public_html/callidon_app
PassengerNodejs /home/prealcac/nodevenv/public_html/callidon_app/20/bin/node
PassengerStartupFile app.cjs

# 3. Permisos explĻŠcitos para evitar el 403
<Files "app.cjs">
    Order allow,deny
    Allow from all
    Require all granted
    SetHandler none
</Files>

